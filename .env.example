# Django settings — copy this to .env and change values
# Generate key: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=YOUR_SERVER_IP,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://YOUR_SERVER_IP
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP
